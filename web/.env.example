# Relationship Copilot (web) — environment template
# Copy to .env.local for Next.js. Never commit real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key
# Server-only (route handlers / server actions / edge functions). Bypasses RLS — keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Grok (xAI), OpenAI-compatible API ---
XAI_API_KEY=your-xai-api-key
XAI_BASE_URL=https://api.x.ai/v1
# Kept as an env var so the current Grok model can change without code edits.
XAI_MODEL=grok-4
# Set to "true" ONLY once an enterprise no-training data agreement (DPA) is in
# place with the AI provider. Production deployments should not enable AI
# features without it; the app surfaces this provider in its user-facing
# disclosures (see the Blueprint/digest pages).
XAI_NO_TRAINING_DPA=false

# --- Stripe (freemium billing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=price_...

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
